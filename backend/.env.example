# .env.example - Backend Configuration

# Database Configuration
# Formato: postgresql://username:password@host:port/database
# LOCAL:    postgresql://postgres:postgres@localhost:5432/controlbook
# RAILWAY:  postgresql://... (obtén de Railway dashboard)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/controlbook

# JWT Configuration
JWT_SECRET=controlbook_secret_key_change_in_production_123

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=debug
